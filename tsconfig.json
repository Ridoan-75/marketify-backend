{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "baseUrl": "."
  },
  "include": ["src/**/*", "generated/**/*"],
  "exclude": ["node_modules", "dist", "prisma"]
}